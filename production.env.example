# Ceylon IT Solutions (CITS) — production environment example
# Copy to .env on the server and fill in real credentials. Do not commit secrets.

APP_NAME="Ceylon IT Solutions"
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://ceylonitsolutions.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database — UPDATE WITH YOUR ACTUAL CREDENTIALS
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ceylonitsolutions_db
DB_USERNAME=ceylonitsolutions_user
DB_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD_HERE

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_business_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@ceylonitsolutions.com"
MAIL_FROM_NAME="Ceylon IT Solutions"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=ap2

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

APP_TIMEZONE="Asia/Colombo"

SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict
SANCTUM_STATEFUL_DOMAINS=ceylonitsolutions.com

UPLOAD_MAX_SIZE=2048
MAX_FILE_UPLOADS=20

COMPANY_NAME="Ceylon IT Solutions"
COMPANY_EMAIL="info@ceylonitsolutions.com"
COMPANY_PHONE="+94 XX XXX XXXX"
COMPANY_ADDRESS="Your business address, Sri Lanka"

GOOGLE_ANALYTICS_ID=
GOOGLE_MAPS_API_KEY=

FACEBOOK_URL="https://www.facebook.com/ceylonitsolutions"
YOUTUBE_URL="https://www.youtube.com/@ceylonitsolutions"
TIKTOK_URL="https://www.tiktok.com/@ceylonitsolutions"
WHATSAPP_NUMBER="+94777506939"

PRODUCT_IMAGE_BASE_URL="https://your-billing-or-erp-domain.example/assets/uploads/"

BACKUP_DISK=local
BACKUP_CLEANUP_DAYS=30

LOG_SLACK_WEBHOOK_URL=
SENTRY_LARAVEL_DSN=

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

FEATURED_PRODUCTS_LIMIT=8
LATEST_PRODUCTS_LIMIT=12
POPULAR_PRODUCTS_LIMIT=6
ITEMS_PER_PAGE=24

FILESYSTEM_DRIVER=local

FORCE_HTTPS=true
HSTS_MAX_AGE=31536000

DB_CONNECTION_POOL_SIZE=10

API_RATE_LIMIT=60
WEB_RATE_LIMIT=1000

ERROR_REPORTING=true
ERROR_EMAIL=admin@ceylonitsolutions.com

MAINTENANCE_SECRET=cits-maintenance-2024

IMAGE_QUALITY=85
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
THUMBNAIL_WIDTH=300
THUMBNAIL_HEIGHT=300
