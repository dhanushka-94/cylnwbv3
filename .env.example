# ==============================================================================
# Ceylon IT Solutions - E-COMMERCE PLATFORM CONFIGURATION
# ==============================================================================
# Environment Configuration File
# Sample / Development Template
# ==============================================================================

# ------------------------------------------------------------------------------
# APPLICATION SETTINGS
# ------------------------------------------------------------------------------
APP_NAME="Ceylon IT Solutions"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://ceylonitsolutions.com

# Application Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Application Maintenance
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Performance Settings
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# Production: set DB_* to the credentials from your host panel. If MySQL fails with
# 127.0.0.1, try DB_HOST=localhost. After fixing .env, run: php artisan config:clear
# Do not upload bootstrap/cache/config.php from a different machine (wrong DB user/host).

# Primary Database (Orders, Users, Transactions)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_main_database
DB_USERNAME=your_main_database_user
DB_PASSWORD=

# Products Database (Read-Only Inventory)
PRODUCTS_DB_HOST=127.0.0.1
PRODUCTS_DB_PORT=3306
PRODUCTS_DB_DATABASE=your_products_database
PRODUCTS_DB_USERNAME=your_products_database_user
PRODUCTS_DB_PASSWORD=

# ------------------------------------------------------------------------------
# PAYMENT GATEWAY INTEGRATIONS
# ------------------------------------------------------------------------------

# PayHere Payment Gateway
# PayHere configuration removed

# WebXPay Credit/Debit Card Processing
WEBXPAY_MODE=live
WEBXPAY_API_USERNAME=your_webxpay_username
WEBXPAY_API_PASSWORD=your_webxpay_password
WEBXPAY_SECRET_KEY=your_webxpay_secret_key
WEBXPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_WEBXPAY_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"
WEBXPAY_CHECKOUT_URL="https://webxpay.com/index.php?route=checkout/billing"
WEBXPAY_RETURN_URL="https://ceylonitsolutions.com/pay/webxpayResponse"
WEBXPAY_CANCEL_URL="https://ceylonitsolutions.com/payment/webxpay/cancel"
WEBXPAY_NOTIFY_URL="https://ceylonitsolutions.com/payment/webxpay/notify"

# KokoPay Buy Now Pay Later (BNPL)
KOKOPAY_MODE=live
KOKOPAY_MERCHANT_ID=your_kokopay_merchant_id
KOKOPAY_API_KEY=your_kokopay_api_key
KOKOPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
YOUR_KOKOPAY_PRIVATE_KEY_HERE
-----END RSA PRIVATE KEY-----"
KOKOPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_KOKOPAY_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"
KOKOPAY_PLUGIN_NAME="Ceylon_IT_Solutions"
KOKOPAY_PLUGIN_VERSION="1"
KOKOPAY_CURRENCY=LKR
KOKOPAY_RETURN_URL="https://ceylonitsolutions.com/payment/kokopay/return"
KOKOPAY_CANCEL_URL="https://ceylonitsolutions.com/payment/kokopay/cancel"
KOKOPAY_NOTIFY_URL="https://ceylonitsolutions.com/payment/kokopay/notify"

# ------------------------------------------------------------------------------
# LOGGING & DEBUGGING
# ------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------------------------
# SESSION & CACHE CONFIGURATION
# ------------------------------------------------------------------------------

# Session Management
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Cache Configuration
CACHE_STORE=database
# CACHE_PREFIX=

# Queue Configuration
QUEUE_CONNECTION=database

# Broadcasting
BROADCAST_CONNECTION=log

# File Storage
FILESYSTEM_DISK=local

# ------------------------------------------------------------------------------
# EXTERNAL SERVICES
# ------------------------------------------------------------------------------

# Memcached Configuration
MEMCACHED_HOST=127.0.0.1

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# EMAIL CONFIGURATION
# ------------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@ceylonitsolutions.com"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------------------------
# AWS CLOUD SERVICES
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------------------------
# FRONTEND BUILD CONFIGURATION
# ------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# Asset Version for Browser Cache Busting
# Increment this value from admin panel to force visitors to download fresh CSS/JS/images
# Format: Unix timestamp (automatically set when incremented)
ASSET_VERSION=1764786519

# ------------------------------------------------------------------------------
# THEME CONFIGURATION
# ------------------------------------------------------------------------------
# Christmas Theme Control
# Set to true to force enable Christmas theme (overrides date-based activation)
# CHRISTMAS_THEME_ENABLED=false

# Set to true to disable Christmas theme even during December
CHRISTMAS_THEME_DISABLED=true

# Note: Christmas theme automatically activates:
# - From December 1st to December 31st
# - Optionally from November 25th to November 30th (early Christmas)

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================